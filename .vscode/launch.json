{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'loserpoint'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=loserpoint",
                    "--package=loserpoint"
                ],
                "filter": {
                    "name": "loserpoint",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_BACKTRACE": "1",
                "RUSTFLAGS": "-A unused-variables"
            },
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Run release build 'loserpoint'",
            "cargo": {
                "args": [
                    "build",
                    "--release",
                    "--bin=loserpoint",
                    "--package=loserpoint"
                ],
                "filter": {
                    "name": "loserpoint",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_BACKTRACE": "1"
            },
        }
    ]
}