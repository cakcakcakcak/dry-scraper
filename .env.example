# Example environment file for dry-scraper
# Copy this to `.env` and customize values for your local/dev environment.
# IMPORTANT: Do NOT commit your real `.env` with secrets to version control.

# Database connection string
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgres://user:pass@localhost:5432/lp

# Logging/tracing level (used by tracing_subscriber)
# Common values: error, warn, info, debug, trace
LOG_LEVEL=info

# Concurrency / performance tuning
# Number of concurrent API requests (requests to NHL APIs)
API_CONCURRENCY_LIMIT=32
# Concurrency for DB batch operations (parallel DB upsert workers)
DB_CONCURRENCY_LIMIT=16

# Maximum number of connections in the Postgres pool
MAX_DB_CONNECTIONS=32

# DB batching behavior
# How many rows to send per DB batch (upsert) operation
DB_QUERY_BATCH_SIZE=1000
# Milliseconds to wait before flushing an incomplete DB batch
DB_QUERY_BATCH_TIMEOUT_MS=2000

# Development convenience flags
# When true, the application will drop certain tables on startup for a clean state.
# Use only in development/testing.
RESET_DB=false

# Retry/backoff configuration (milliseconds)
RETRY_INTERVAL_MS=100
RETRY_MAX_INTERVAL_MS=10000
RETRIES=5

# Optional: override API base URLs (useful for testing with mocks)
# NHL_STATS_API_BASE_URL=https://api.nhle.com/stats/rest/en
# NHL_WEB_API_BASE_URL=https://api-web.nhle.com/v1

# Optional: additional runtime tuning or feature flags
# Example: enable a spinner/progress UI even when non-interactive
# FORCE_PROGRESS=false

# End of file
